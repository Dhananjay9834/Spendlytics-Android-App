<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Permissions ──────────────────────────────────────── -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.RECEIVE_SMS"/>
    <uses-permission android:name="android.permission.READ_SMS"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/icon_foreground"
        android:roundIcon="@mipmap/icon_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ExpenseTracker"
        tools:targetApi="31">

        <!-- ══════════════════════════════════════════════════ -->
        <!--         SPLASH SCREEN  (LAUNCHER)                 -->
        <!-- ══════════════════════════════════════════════════ -->
        <activity
            android:name="com.example.spendlytics.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.ExpenseTracker.Splash"
            android:screenOrientation="portrait">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- ══════════════════════════════════════════════════ -->
        <!--         LOGIN SCREEN                              -->
        <!-- ══════════════════════════════════════════════════ -->
        <activity
            android:name="com.example.spendlytics.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <!-- ══════════════════════════════════════════════════ -->
        <!--         OTP VERIFICATION                          -->
        <!-- ══════════════════════════════════════════════════ -->
        <activity
            android:name="com.example.spendlytics.OtpActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <!-- ══════════════════════════════════════════════════ -->
        <!--         MAIN DASHBOARD                            -->
        <!-- ══════════════════════════════════════════════════ -->
        <activity
            android:name="com.example.spendlytics.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <!-- ══════════════════════════════════════════════════ -->
        <!--         ADD EXPENSE                               -->
        <!-- ══════════════════════════════════════════════════ -->
        <activity
            android:name="com.example.spendlytics.AddExpenseActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName="com.example.spendlytics.MainActivity"/>

        <!-- ══════════════════════════════════════════════════ -->
        <!--         ANALYSIS DASHBOARD                        -->
        <!-- ══════════════════════════════════════════════════ -->
        <activity
            android:name="com.example.spendlytics.AnalysisActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName="com.example.spendlytics.MainActivity"/>

        <!-- ══════════════════════════════════════════════════ -->
        <!--         CHARTS PAGE                               -->
        <!-- ══════════════════════════════════════════════════ -->
        <activity
            android:name="com.example.spendlytics.ChartActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName="com.example.spendlytics.MainActivity"/>

    </application>

</manifest>